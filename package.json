{
  "name": "sonarlens",
  "displayName": "SonarLens",
  "description": "Fetch SonarQube issues and fix them using AI",
  "version": "0.1.0",
  "publisher": "sonarlens",
  "repository": {
    "type": "git",
    "url": "https://github.com/cB-Amrit-Anand/sonarlens"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sonarlens-container",
          "title": "SonarLens",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "sonarlens-container": [
        {
          "type": "webview",
          "id": "sonarlens.sidebar",
          "name": "SonarLens"
        }
      ]
    },
    "commands": [
      {
        "command": "sonarlens.openPanel",
        "title": "Open in Editor Tab",
        "icon": "$(link-external)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "sonarlens.openPanel",
          "when": "view == sonarlens.sidebar",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "axios": "^1.6.0",
    "openai": "^6.34.0"
  }
}
